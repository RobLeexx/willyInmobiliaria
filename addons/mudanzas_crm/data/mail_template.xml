<odoo>
  <record id="mail_template_mudanza_oferta" model="mail.template">
    <field name="name">Oferta de mudanza (ES)</field>
    <field name="model_id" ref="crm.model_crm_lead"/>
    <field name="subject">Presupuesto de Mudanzas Willy</field>
    <field name="email_from">Mudanzas Willy &lt;oficinamudanzaswilly@gmail.com&gt;</field>
    <field name="email_to">{{ object.email_from or '' }}</field>
    <field name="email_cc">{{ object.offer_email_cc or '' }}</field>
    <field name="reply_to"></field>
    <field name="report_template_ids" eval="[(6, 0, [ref('mudanzas_crm.action_report_mudanzas_offer')])]"/>
    <field name="auto_delete" eval="False"/>
    <field name="body_html"><![CDATA[
<div style="font-family: Arial, sans-serif; font-size: 14px;">
  <p>Hola <t t-out="object.contact_name or object.partner_id.name or 'cliente'"/>,</p>
  <p>Adjuntamos el presupuesto de tu mudanza en formato PDF.</p>
  <p>Si estas de acuerdo, responde a este correo y coordinamos fecha, horario y detalles de ejecucion.</p>
  <p>El envío de presupuesto esta en pruebas, si detecta alguna anomalía o error, por favor indícanosla.</p>
  <p>Un saludo,<br/><t t-out="object.company_id.name"/></p>
</div>
    ]]></field>
  </record>
  <function model="mail.template" name="mudanzas_set_offer_lang"/>
</odoo>
