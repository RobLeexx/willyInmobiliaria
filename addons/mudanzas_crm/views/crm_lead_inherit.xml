<odoo>
  <data>
    <record id="crm.crm_lead_action_pipeline" model="ir.actions.act_window">
      <field name="context">{
        'default_type': 'opportunity',
        'show_user_team_stages': 1,
      }</field>
    </record>

    <record id="mudanzas_crm_crm_lead_form_inherit" model="ir.ui.view">
      <field name="name">mudanzas.crm.lead.form.inherit</field>
      <field name="model">crm.lead</field>
      <field name="inherit_id" ref="crm.crm_lead_view_form"/>
      <field name="arch" type="xml">
        <xpath expr="//header" position="inside">
          <button name="action_send_offer_email" type="object" string="Enviar oferta por email" class="btn-primary" invisible="not email_from"/>
        </xpath>
        <xpath expr="//field[@name='partner_name']" position="replace"/>
        <xpath expr="//field[@name='function']" position="replace"/>
        <xpath expr="//field[@name='partner_id']" position="replace"/>
        <xpath expr="//field[@name='email_from']" position="replace"/>
        <xpath expr="//field[@name='phone']" position="replace"/>
        <xpath expr="//field[@name='user_id']" position="replace"/>
        <xpath expr="//field[@name='tag_ids']" position="replace"/>
        <xpath expr="//field[@name='priority']" position="replace"/>
        <xpath expr="//field[@name='date_deadline']" position="attributes">
          <attribute name="invisible">1</attribute>
        </xpath>
        <xpath expr="//div[contains(@class, 'oe_title') and contains(@class, 'mw-100')]" position="attributes">
          <attribute name="class" add=" mudanzas-sticky-header" separator=" "/>
        </xpath>
        <xpath expr="//group[@name='lead_info']" position="replace"/>
        <xpath expr="//group[@name='lead_priority']" position="replace"/>
        <xpath expr="//group[@name='opportunity_partner']" position="replace"/>
        <xpath expr="//label[@for='date_deadline']" position="replace"/>
        <xpath expr="//group[@name='lead_partner']" position="replace">
          <group col="16" class="col-lg-9" style="padding-right: 0; width: 100%;">
            <group col="2" colspan="16">
              <separator string="Cliente y Lead" colspan="2"/>
              <group col="1">
                <field
                  name="partner_id"
                  widget="res_partner_many2one"
                  context="{
                    'default_parent_id': commercial_partner_id,
                    'default_name': contact_name,
                    'default_phone': phone,
                    'default_email': email_from,
                    'default_user_id': user_id,
                    'default_team_id': team_id,
                    'default_lang': lang_code
                  }"
                  options="{'no_create_edit': False}"
                />
                <field name="email_from" widget="email"/>
                <field name="phone" widget="phone"/>
                <field name="user_id" context="{'default_sales_team_id': team_id}" widget="many2one_avatar_leader_user" teamField="team_id"/>
              </group>
              <group col="1">
                <field name="partner_medio_contacto" invisible="partner_medio_contacto" class="mudanzas-alert-field"/>
                <field name="partner_medio_contacto" invisible="not partner_medio_contacto"/>
                <field name="partner_medio_contacto_otro" invisible="partner_medio_contacto != 'llamada_otros'" required="partner_medio_contacto == 'llamada_otros'"/>
                <field name="partner_vat"/>
                <field name="priority" widget="priority"/>
                <field name="tag_ids" widget="many2many_tags" options="{'color_field': 'color', 'no_create_edit': True}"/>
              </group>
            </group>

          <div class="row mudanzas-full-row" invisible="not partner_medio_contacto">
            <div class="col-6 mr-0 pr-0 w-50">
              <group string="Carga" col="4">
                <field name="streetup" placeholder="Calle..." class="o_address_street mudanzas-soft-field" colspan="3"/>
                <i class="fa fa-arrow-right" role="img" aria-label="De carga a descarga" colspan="1"/>
                <field name="streetup2" placeholder="Calle 2..." class="o_address_street mudanzas-soft-field" colspan="3"/>
                <i class="fa fa-arrow-right" role="img" aria-label="De carga a descarga" colspan="1"/>
                <field name="doorup" placeholder="Puerta" class="o_address_zip mudanzas-soft-field" colspan="3"/>
                <i class="fa fa-arrow-right" role="img" aria-label="De carga a descarga" colspan="1"/>
                <field name="state_up" class="o_address_state mudanzas-soft-field" placeholder="Estado" options="{'no_open': True}" colspan="3"/>
                <i class="fa fa-arrow-right" role="img" aria-label="De carga a descarga" colspan="1"/>
                <field name="province_up_id" class="o_address_state mudanzas-soft-field" placeholder="Provincia" options="{'no_open': True, 'no_create': True, 'no_create_edit': True}" domain="[('state', '=', state_up)]" colspan="3"/>
                <i class="fa fa-arrow-right" role="img" aria-label="De carga a descarga" colspan="1"/>
                <field name="poblation_up" placeholder="Población" class="o_address_city mudanzas-soft-field" colspan="3"/>
                <i class="fa fa-arrow-right" role="img" aria-label="De carga a descarga" colspan="1"/>
                <field name="elevatorup" placeholder="Ascensor" class="o_address_zip mudanzas-soft-field" invisible="elevatorup" colspan="3"/>
                <field name="elevatorup" class="o_address_zip" invisible="elevatorup != 'tiene'" style="border: 1px solid #8ecae6; background-color: #e8f7ff; color: #0b5f7a; padding: 4px;" colspan="3"/>
                <field name="elevatorup" class="o_address_zip" invisible="elevatorup != 'no_tiene'" style="border: 1px solid #e7b26a; background-color: #fff2e2; color: #9a4d00; padding: 4px;" colspan="3"/>
                <field name="floorup" placeholder="Piso" class="o_address_city" invisible="floorup &gt;= 2" style="border: 1px solid #8ecae6; background-color: #e8f7ff; color: #0b5f7a; padding: 4px;" colspan="3"/>
                <field name="floorup" class="o_address_city" invisible="floorup &lt; 2 or floorup &gt;= 4" style="border: 1px solid #d8c27a; background-color: #fff7da; color: #8a6a00; padding: 4px;" colspan="3"/>
                <field name="floorup" class="o_address_city" invisible="floorup &lt; 4 or floorup &gt;= 6" style="border: 1px solid #e7b26a; background-color: #fff0d9; color: #9a4d00; padding: 4px;" colspan="3"/>
                <field name="floorup" class="o_address_city" invisible="floorup &lt; 6 or floorup &gt;= 8" style="border: 1px solid #d98a8a; background-color: #ffe3e3; color: #a12626; padding: 4px;" colspan="3"/>
                <field name="floorup" class="o_address_city" invisible="floorup &lt; 8" style="border: 1px solid #d98a8a; background-color: #ffe3e3; color: #a12626; padding: 4px;" colspan="4"/>
                <i class="fa fa-arrow-right" role="img" aria-label="De carga a descarga" colspan="1"/>
              </group>
            </div>

            <div class="col-6 w-50">
              <group string="Descarga" col="4">
                <field name="streetdown" placeholder="Calle..." class="o_address_street mudanzas-soft-field" colspan="4"/>
                <field name="streetdown2" placeholder="Calle 2..." class="o_address_street mudanzas-soft-field" colspan="4"/>
                <field name="doordown" placeholder="Puerta" class="o_address_zip mudanzas-soft-field" colspan="4"/>
                <field name="state_down" class="o_address_state mudanzas-soft-field" placeholder="Estado" options="{'no_open': True}" colspan="4"/>
                <field name="province_down_id" class="o_address_state mudanzas-soft-field" placeholder="Provincia" options="{'no_open': True, 'no_create': True, 'no_create_edit': True}" domain="[('state', '=', state_down)]" colspan="4"/>
                <field name="poblation_down" placeholder="Población" class="o_address_city mudanzas-soft-field" colspan="4"/>
                <field name="elevatordown" placeholder="Ascensor" class="o_address_zip mudanzas-soft-field" invisible="elevatordown" colspan="4"/>
                <field name="elevatordown" class="o_address_zip" invisible="elevatordown != 'tiene'" style="border: 1px solid #8ecae6; background-color: #e8f7ff; color: #0b5f7a; padding: 4px;" colspan="4"/>
                <field name="elevatordown" class="o_address_zip" invisible="elevatordown != 'no_tiene'" style="border: 1px solid #e7b26a; background-color: #fff2e2; color: #9a4d00; padding: 4px;" colspan="4"/>
                <field name="floordown" placeholder="Piso" class="o_address_city" invisible="floordown &gt;= 2" style="border: 1px solid #8ecae6; background-color: #e8f7ff; color: #0b5f7a; padding: 4px;" colspan="4"/>
                <field name="floordown" class="o_address_city" invisible="floordown &lt; 2 or floordown &gt;= 4" style="border: 1px solid #d8c27a; background-color: #fff7da; color: #8a6a00; padding: 4px;" colspan="4"/>
                <field name="floordown" class="o_address_city" invisible="floordown &lt; 4 or floordown &gt;= 6" style="border: 1px solid #e7b26a; background-color: #fff0d9; color: #9a4d00; padding: 4px;" colspan="4"/>
                <field name="floordown" class="o_address_city" invisible="floordown &lt; 6 or floordown &gt;= 8" style="border: 1px solid #d98a8a; background-color: #ffe3e3; color: #a12626; padding: 4px;" colspan="3"/>
                <field name="floordown" class="o_address_city" invisible="floordown &lt; 8" style="border: 1px solid #d98a8a; background-color: #ffe3e3; color: #a12626; padding: 4px;" colspan="4"/>
              </group>
            </div>
          </div>

          <separator string="Mudanza" colspan="16" invisible="not partner_medio_contacto"/>
            <group col="6" colspan="9" class="w-100" invisible="not partner_medio_contacto">
              <field name="mudanza_line_ids" colspan="6">
                <list editable="bottom">
                  <field name="cantidad"/>
                  <field name="objeto_catalogo_id" options="{'no_open': True, 'no_create': True, 'no_create_edit': True}"/>
                  <field name="objeto_es_otro" column_invisible="True"/>
                  <field name="objeto_manual" invisible="not objeto_es_otro" required="objeto_es_otro"/>
                  <field name="volumen"/>
                  <field name="embalaje"/>
                  <field name="desmontaje"/>
                  <field name="habitacion"/>
                </list>
                <form>
                  <group col="2">
                    <field name="cantidad"/>
                    <field name="objeto_catalogo_id" options="{'no_open': True, 'no_create': True, 'no_create_edit': True}"/>
                    <field name="objeto_es_otro" invisible="1"/>
                    <field name="objeto_manual" invisible="not objeto_es_otro" required="objeto_es_otro"/>
                    <field name="peso"/>
                    <field name="embalaje" class="me-2"/>
                    <field name="desmontaje"/>
                    <field name="habitacion"/>
                  </group>
                </form>
              </field>
            </group>
            <group string="Programacion de mudanzas" colspan="14" invisible="not partner_medio_contacto">
              <field name="fecha_mudanza" widget="date" options="{'datepicker': {'firstDay': 1}}" class="oe_inline" placeholder="Fecha de mudanza"/>
              <field name="horas"/>
              <field name="mas_de_dos_dias"/>
              <field name="elevador"/>
              <field name="horas_elevador" invisible="not elevador"/>
            </group>
          </group>

          <group col="1" colspan="16" class="col-12 w-100 mudanzas-media-section" invisible="not partner_medio_contacto">
            <field
              name="mudanza_media_ids"
              colspan="16"
              widget="many2many_binary"
              options="{'no_create': True, 'no_open': True}"
              context="{'default_res_model': 'crm.lead', 'default_res_id': id}"
              domain="[('res_model', '=', 'crm.lead'), ('res_id', '=', id)]"
              class="mudanzas-media-upload"
            />
            <field name="mudanza_media_preview" colspan="16" widget="html" nolabel="1" readonly="1" class="mudanzas-media-preview"/>
          </group>

          <div class="row mudanzas-full-row" invisible="not partner_medio_contacto">
            <div class="col-6 mr-0 pr-0 w-50">
              <group string="Oferta">
                <field name="precio_oferta" class="mudanzas-soft-field me-1"/>
                <field name="tipo_oferta" class="mudanzas-soft-field me-1"/>
              </group>
            </div>
            <div class="col-6 mr-0 pr-0 w-50">
              <group string="Servicios adicionales">
                <field name="offer_include_client_boxes_transport"/>
                <field name="offer_client_boxes_quantity" invisible="not offer_include_client_boxes_transport"/>
                <field name="offer_include_storage"/>
                <field name="offer_storage_months" invisible="not offer_include_storage"/>
              </group>
            </div>
          </div>

          <separator style="border-top: 2px solid black;"/>

        </xpath>
      </field>
    </record>
  </data>
</odoo>
