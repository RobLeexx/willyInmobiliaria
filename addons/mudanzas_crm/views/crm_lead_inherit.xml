<odoo>
  <data>
    <record id="mudanzas_crm_crm_lead_form_inherit" model="ir.ui.view">
      <field name="name">mudanzas.crm.lead.form.inherit</field>
      <field name="model">crm.lead</field>
      <field name="inherit_id" ref="crm.crm_lead_view_form"/>
      <field name="arch" type="xml">
        <xpath expr="//header" position="inside">
          <button name="action_send_offer_email" type="object" string="Enviar oferta por email" class="btn-primary" invisible="not email_from"/>
        </xpath>
        <xpath expr="//field[@name='partner_name']" position="replace"/>
        <xpath expr="//field[@name='function']" position="replace"/>
        <xpath expr="//field[@name='partner_id']" position="replace"/>
        <xpath expr="//field[@name='email_from']" position="replace"/>
        <xpath expr="//field[@name='phone']" position="replace"/>
        <xpath expr="//field[@name='user_id']" position="replace"/>
        <xpath expr="//field[@name='tag_ids']" position="replace"/>
        <xpath expr="//field[@name='priority']" position="replace"/>
        <xpath expr="//field[@name='date_deadline']" position="attributes">
          <attribute name="invisible">1</attribute>
        </xpath>
        <xpath expr="//group[@name='lead_info']" position="replace"/>
        <xpath expr="//group[@name='lead_priority']" position="replace"/>
        <xpath expr="//group[@name='opportunity_partner']" position="replace"/>
        <xpath expr="//label[@for='date_deadline']" position="replace"/>
        <xpath expr="//group[@name='lead_partner']" position="replace">
          <group col="16" class="col-lg-9" style="padding-right: 0;">
            <group col="2" colspan="16">
              <separator string="Cliente y Lead" colspan="2"/>
              <group col="1">
                <field
                  name="partner_id"
                  widget="res_partner_many2one"
                  context="{
                    'default_parent_id': commercial_partner_id,
                    'default_name': contact_name,
                    'default_phone': phone,
                    'default_email': email_from,
                    'default_user_id': user_id,
                    'default_team_id': team_id,
                    'default_lang': lang_code
                  }"
                  options="{'no_create_edit': False}"
                />
                <field name="email_from" widget="email"/>
                <field name="phone" widget="phone"/>
                <field name="user_id" context="{'default_sales_team_id': team_id}" widget="many2one_avatar_leader_user" teamField="team_id"/>
              </group>
              <group col="1">
                <field name="partner_medio_contacto" invisible="partner_medio_contacto" style="font-weight: 700; color: #8a1c1c; background-color: #fde8e8; border: 1px solid #e5a3a3; padding: 4px;"/>
                <field name="partner_medio_contacto" invisible="not partner_medio_contacto"/>
                <field name="partner_medio_contacto_otro" invisible="partner_medio_contacto != 'llamada_otros'" required="partner_medio_contacto == 'llamada_otros'"/>
                <field name="partner_vat"/>
                <field name="priority" widget="priority"/>
                <field name="tag_ids" widget="many2many_tags" options="{'color_field': 'color', 'no_create_edit': True}"/>
              </group>
            </group>
            <separator string="Mudanza" colspan="16" invisible="not partner_medio_contacto"/>
            <group col="6" colspan="9" class="w-100" invisible="not partner_medio_contacto">
              <field name="mudanza_line_ids" colspan="6">
                <list editable="bottom">
                  <field name="cantidad"/>
                  <field name="objeto_catalogo_id" options="{'no_open': True, 'no_create': True, 'no_create_edit': True}"/>
                  <field name="objeto_es_otro" column_invisible="True"/>
                  <field name="objeto_manual" invisible="not objeto_es_otro" required="objeto_es_otro"/>
                  <field name="volumen"/>
                  <field name="embalaje"/>
                  <field name="desmontaje"/>
                  <field name="habitacion"/>
                </list>
                <form>
                  <group col="2">
                    <field name="cantidad"/>
                    <field name="objeto_catalogo_id" options="{'no_open': True, 'no_create': True, 'no_create_edit': True}"/>
                    <field name="objeto_es_otro" invisible="1"/>
                    <field name="objeto_manual" invisible="not objeto_es_otro" required="objeto_es_otro"/>
                    <field name="peso"/>
                    <field name="embalaje" style="margin-right: 8px;"/>
                    <field name="desmontaje"/>
                    <field name="habitacion"/>
                  </group>
                </form>
              </field>
            </group>
            <div colspan="14" invisible="not partner_medio_contacto">
              <label for="observaciones_mudanza" style="font-weight: bold; margin-bottom: 4px;">Observaciones</label>
              <field name="observaciones_mudanza" style="border: 1px solid #999; background-color: rgba(0, 0, 0, 0.08)"/>
            </div>
            <group string="Programacion de mudanzas" colspan="14" invisible="not partner_medio_contacto">
              <field name="fecha_mudanza" widget="date" options="{'datepicker': {'firstDay': 1}}" class="oe_inline" placeholder="Fecha de mudanza"/>
              <field name="horas"/>
              <field name="ascensor"/>
              <field name="mas_de_dos_dias"/>
              <field name="elevador"/>
              <field name="horas_elevador" invisible="not elevador"/>
            </group>
          </group>

          <group string="Fotos y Videos" class="col-12 w-100" style="flex: 0 0 100%; max-width: 100%; border-top: 1px solid #ddd; padding-top: 16px; margin-top: 12px;" invisible="not partner_medio_contacto">
            <field
              name="mudanza_media_ids"
              widget="many2many_binary"
              options="{'no_create': True, 'no_open': True}"
              context="{'default_res_model': 'crm.lead', 'default_res_id': id}"
              domain="[('res_model', '=', 'crm.lead'), ('res_id', '=', id)]"
              style="width: 100%; border: 1px solid #999; background-color: rgba(0, 0, 0, 0.08); padding: 8px;"
            />
            <field name="mudanza_media_preview" widget="html" nolabel="1" readonly="1" style="width: 100%;"/>
          </group>

          <div class="col-lg-5" style="flex: 0 0 33%; max-width: 33%;" invisible="not partner_medio_contacto">
            <div class="row">
              <div class="w-100">
                <group string="Oferta">
                  <field name="precio_oferta" style="border: 1px solid #999; background-color: rgba(0, 0, 0, 0.08); margin-right: 4px;"/>
                  <field name="tipo_oferta" style="border: 1px solid #999; background-color: rgba(0, 0, 0, 0.08); margin-right: 4px;"/>
                </group>
              </div>
            </div>
          </div>

          <div class="row" style="flex: 0 0 100%; max-width: 100%;" invisible="not partner_medio_contacto">
            <div class="col-6 mr-0 pr-0 w-50">
              <group string="Carga" col="4">
                <field name="streetup" placeholder="Calle..." class="o_address_street" style="border: 1px solid #999; background-color: rgba(0, 0, 0, 0.08); padding: 4px;" colspan="3"/>
                <i class="fa fa-arrow-right" role="img" aria-label="De carga a descarga" colspan="1"/>
                <field name="streetup2" placeholder="Calle 2..." class="o_address_street" style="border: 1px solid #999; background-color: rgba(0, 0, 0, 0.08); padding: 4px;" colspan="3"/>
                <i class="fa fa-arrow-right" role="img" aria-label="De carga a descarga" colspan="1"/>
                <field name="doorup" placeholder="Puerta" class="o_address_zip" style="border: 1px solid #999; background-color: rgba(0, 0, 0, 0.08); padding: 4px;" colspan="3"/>
                <i class="fa fa-arrow-right" role="img" aria-label="De carga a descarga" colspan="1"/>
                <field name="elevatorup" placeholder="Ascensor" class="o_address_zip" style="border: 1px solid #999; background-color: rgba(0, 0, 0, 0.08); padding: 4px;" colspan="3"/>
                <i class="fa fa-arrow-right" role="img" aria-label="De carga a descarga" colspan="1"/>
                <field name="floorup" placeholder="Piso" class="o_address_city" style="border: 1px solid #999; background-color: rgba(0, 0, 0, 0.08); padding: 4px;" colspan="3"/>
                <i class="fa fa-arrow-right" role="img" aria-label="De carga a descarga" colspan="1"/>
                <field name="state_up" class="o_address_state" placeholder="Estado" style="border: 1px solid #999; background-color: rgba(0, 0, 0, 0.08); padding: 4px;" options="{'no_open': True}" colspan="3"/>
                <i class="fa fa-arrow-right" role="img" aria-label="De carga a descarga" colspan="1"/>
                <field name="province_up_id" class="o_address_state" placeholder="Provincia" style="border: 1px solid #999; background-color: rgba(0, 0, 0, 0.08); padding: 4px;" options="{'no_open': True, 'no_create': True, 'no_create_edit': True}" domain="[('state', '=', state_up)]" colspan="3"/>
                <i class="fa fa-arrow-right" role="img" aria-label="De carga a descarga" colspan="1"/>
                <field name="poblation_up" placeholder="Población" class="o_address_city" style="border: 1px solid #999; background-color: rgba(0, 0, 0, 0.08); padding: 4px;" colspan="3"/>
                <i class="fa fa-arrow-right" role="img" aria-label="De carga a descarga" colspan="1"/>
              </group>
            </div>

            <div class="col-6 w-50">
              <group string="Descarga" col="4">
                <field name="streetdown" placeholder="Calle..." class="o_address_street" style="border: 1px solid #999; background-color: rgba(0, 0, 0, 0.08); padding: 4px;" colspan="4"/>
                <field name="streetdown2" placeholder="Calle 2..." class="o_address_street" style="border: 1px solid #999; background-color: rgba(0, 0, 0, 0.08); padding: 4px;" colspan="4"/>
                <field name="doordown" placeholder="Puerta" class="o_address_zip" style="border: 1px solid #999; background-color: rgba(0, 0, 0, 0.08); padding: 4px;" colspan="4"/>
                <field name="elevatordown" placeholder="Ascensor" class="o_address_zip" style="border: 1px solid #999; background-color: rgba(0, 0, 0, 0.08); padding: 4px;" colspan="4"/>
                <field name="floordown" placeholder="Piso" class="o_address_city" style="border: 1px solid #999; background-color: rgba(0, 0, 0, 0.08); padding: 4px;" colspan="4"/>
                <field name="state_down" class="o_address_state" placeholder="Estado" style="border: 1px solid #999; background-color: rgba(0, 0, 0, 0.08); padding: 4px;" options="{'no_open': True}" colspan="4"/>
                <field name="province_down_id" class="o_address_state" placeholder="Provincia" style="border: 1px solid #999; background-color: rgba(0, 0, 0, 0.08); padding: 4px;" options="{'no_open': True, 'no_create': True, 'no_create_edit': True}" domain="[('state', '=', state_down)]" colspan="4"/>
                <field name="poblation_down" placeholder="Población" class="o_address_city" style="border: 1px solid #999; background-color: rgba(0, 0, 0, 0.08); padding: 4px;" colspan="4"/>
              </group>
            </div>
          </div>

          <separator style="border-top: 2px solid black;"/>

        </xpath>
      </field>
    </record>
  </data>
</odoo>
